# ---- server ----
PORT=8080
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h

# ---- first-run admin seed (used only when the users table is empty) ----
ADMIN_USERNAME=muxi
ADMIN_PASSWORD=change-me

# ---- database ----
# Either set DATABASE_URL directly, or the POSTGRES_* parts below.
# DATABASE_URL=host=localhost port=5432 user=postgres password=pureblog dbname=pureblog sslmode=disable TimeZone=UTC
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=pureblog
POSTGRES_DB=pureblog
POSTGRES_SSLMODE=disable

# ---- CORS (comma-separated origins) ----
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
